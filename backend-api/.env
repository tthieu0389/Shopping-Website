PORT=3000

# KET NOI DATABASE CHINH (SQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=your_database_name

# BAO MAT JWT - dat mot chuoi ngau nhien, du dai, khong dung gia tri vi du nay
JWT_SECRET=change_this_to_a_random_secret

# MOI TRUONG CHAY: Sua thanh production khi deploy thuc te
NODE_ENV=development

# DIA CHI FRONTEND: Dan link ngrok hoac domain thuc te cua Frontend vao day khi deploy
CLIENT_URL=http://localhost:5173
